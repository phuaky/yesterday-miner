# Telegram approval surface
TELEGRAM_BOT_TOKEN=<real Telegram bot token>
TELEGRAM_CHAT_ID=<real Telegram chat id>

# Product/operator labels for the dry-run demo
PRODUCT_SPEC_PATH=product.md
PRODUCT_NAME=<real product name>
OPERATOR_NAME=<operator name>
TARGET_AUDIENCE=<one-line audience>
X_HANDLE=<operator X handle>

# Optional: enables AI composition. If omitted, demo uses local template fallback.
OPENAI_API_KEY=

# Safety switches for the operator dry run
DRY_RUN=1
KILL_SWITCH=0
DAILY_POST_CAP=5
GRACE_PERIOD_SECONDS=10
