#!/usr/bin/env bun

import { spawnSync } from "node:child_process";
import { existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
import { dirname, resolve } from "node:path";

const harnessRoot = resolve(import.meta.dir, "..");
const resultPath = resolve(harnessRoot, "test-results/demo-run.json");
const sendPath = resolve(harnessRoot, "test-results/demo-send-drafts.json");

function runStep(name: string, args: string[]): { ok: boolean; exitCode: number | null } {
  console.log(`\n== ${name} ==`);
  const result = spawnSync("bun", args, {
    cwd: harnessRoot,
    env: process.env,
    stdio: "inherit",
  });
  return { ok: result.status === 0, exitCode: result.status };
}

function writeResult(status: string, stage: string, nextSteps: string[]): void {
  mkdirSync(dirname(resultPath), { recursive: true });
  const sendResult = existsSync(sendPath) ? JSON.parse(readFileSync(sendPath, "utf8")) as unknown : null;
  writeFileSync(resultPath, `${JSON.stringify({
    status,
    stage,
    checkedAt: new Date().toISOString(),
    harnessRoot,
    sendResult,
    nextSteps,
    safetyEvidence: {
      livePublishAttempted: false,
      autoDmAttempted: false,
      secretValuesPrinted: false,
    },
  }, null, 2)}\n`);
}

const ready = runStep("readiness", ["run", "demo:ready"]);
if (!ready.ok) {
  writeResult("blocked", "readiness", ["Fill the missing private inputs reported by demo:ready."]);
  process.exit(ready.exitCode ?? 1);
}

const sent = runStep("send drafts", ["run", "demo:send"]);
if (!sent.ok) {
  writeResult("blocked", "send", ["Fix the issue reported by demo:send."]);
  process.exit(sent.exitCode ?? 1);
}

writeResult("awaiting-approval", "telegram-callbacks", [
  "Run `bun run bot` in this directory if it is not already running.",
  "In Telegram, click Post on the personal draft.",
  "Click STOP during the grace window or let the dry-run post complete.",
  "Run `bun run demo:proof` after the callback.",
]);

console.log("\nPASS drafts sent. Awaiting Telegram approval proof.");
console.log("Next:");
console.log("  1. bun run bot");
console.log("  2. click Post / STOP in Telegram");
console.log("  3. bun run demo:proof");
console.log("wrote: test-results/demo-run.json");
