#!/usr/bin/env bun

import { existsSync, mkdirSync, readFileSync, readdirSync, statSync, writeFileSync } from "node:fs";
import { dirname, relative, resolve } from "node:path";
import { criteria, pendingTasks, readSpec, unfulfilledHumanInputs } from "../parser/spec.ts";

type Status = "pass" | "warn" | "fail";

type Check = {
  name: string;
  status: Status;
  evidence: string;
  details?: string[];
};

type Manifest = {
  name: string;
  commands: Array<{ name: string; command: string; safetyRequired?: string[] }>;
  env: Array<{ name: string; secret: boolean; requiredFor: string[] }>;
  inputs: Array<{ path: string }>;
  outputs: Array<{ path: string }>;
  stateFiles: Array<{ path: string; policy: string }>;
  safetyGates: Array<{ name: string; behavior: string }>;
  readinessGate: string[];
};

const harnessRoot = resolve(import.meta.dir, "..");
const projectRoot = resolve(harnessRoot, "..");
const resultPath = resolve(harnessRoot, "test-results/.last-run.json");
const checks: Check[] = [];

function rel(path: string): string {
  return relative(harnessRoot, path) || ".";
}

function add(name: string, status: Status, evidence: string, details?: string[]): void {
  checks.push({ name, status, evidence, details });
}

function readJson<T>(path: string): T | null {
  try {
    return JSON.parse(readFileSync(path, "utf8")) as T;
  } catch {
    return null;
  }
}

function envKeys(path: string): Set<string> {
  if (!existsSync(path)) return new Set();
  const keys = new Set<string>();
  for (const rawLine of readFileSync(path, "utf8").split("\n")) {
    const line = rawLine.trim();
    if (!line || line.startsWith("#")) continue;
    const m = line.match(/^([A-Za-z_][A-Za-z0-9_]*)=/);
    if (m) keys.add(m[1]!);
  }
  return keys;
}

function allFiles(dir: string, out: string[] = []): string[] {
  if (!existsSync(dir)) return out;
  for (const name of readdirSync(dir)) {
    if (name === "node_modules" || name === ".git") continue;
    const path = resolve(dir, name);
    const stat = statSync(path);
    if (stat.isDirectory()) allFiles(path, out);
    else out.push(path);
  }
  return out;
}

function gitCheckIgnored(pathFromProjectRoot: string): boolean | null {
  if (!existsSync(resolve(projectRoot, ".git"))) return null;
  const proc = Bun.spawnSync(["git", "-C", projectRoot, "check-ignore", "-q", pathFromProjectRoot]);
  return proc.exitCode === 0;
}

function duplicates(items: string[]): string[] {
  const seen = new Set<string>();
  const out = new Set<string>();
  for (const item of items) {
    if (seen.has(item)) out.add(item);
    seen.add(item);
  }
  return [...out];
}

function missingFrom(expected: string[], actual: Set<string>): string[] {
  return expected.filter((item) => !actual.has(item));
}

const requiredFiles = [
  resolve(projectRoot, "templates/product.template.md"),
  resolve(harnessRoot, "README.md"),
  resolve(harnessRoot, "package.json"),
  resolve(harnessRoot, "harness.manifest.json"),
  resolve(harnessRoot, ".env.example"),
  resolve(harnessRoot, ".gitignore"),
  resolve(projectRoot, ".gitignore"),
  resolve(harnessRoot, "ralph.ts"),
  resolve(harnessRoot, "lib/config.ts"),
  resolve(harnessRoot, "parser/spec.ts"),
  resolve(harnessRoot, "publish/safety.ts"),
  resolve(harnessRoot, "publish/x-post.ts"),
  resolve(harnessRoot, "telegram/bot.ts"),
  resolve(harnessRoot, "telegram/send.ts"),
  resolve(harnessRoot, "docs/architecture.md"),
  resolve(harnessRoot, "docs/state-map.md"),
  resolve(harnessRoot, "docs/events.md"),
  resolve(harnessRoot, "docs/readiness-gate.md"),
  resolve(harnessRoot, "docs/operator-dry-run-demo.md"),
  resolve(harnessRoot, "docs/demo.env.example"),
  resolve(harnessRoot, "docs/demo-input.example.json"),
  resolve(harnessRoot, "scripts/demo-approval-proof"),
  resolve(harnessRoot, "scripts/demo-bootstrap"),
  resolve(harnessRoot, "scripts/demo-date.ts"),
  resolve(harnessRoot, "scripts/demo-handoff.ts"),
  resolve(harnessRoot, "scripts/demo-local-safety"),
  resolve(harnessRoot, "scripts/demo-operator"),
  resolve(harnessRoot, "scripts/demo-readiness"),
  resolve(harnessRoot, "scripts/demo-run"),
  resolve(harnessRoot, "scripts/demo-send-drafts"),
  resolve(harnessRoot, "scripts/demo-status")
];

const missingFiles = requiredFiles.filter((path) => !existsSync(path)).map(rel);
add(
  "required files",
  missingFiles.length === 0 ? "pass" : "fail",
  missingFiles.length === 0 ? `${requiredFiles.length} required files exist.` : "Required files are missing.",
  missingFiles
);

const manifestPath = resolve(harnessRoot, "harness.manifest.json");
const manifest = readJson<Manifest>(manifestPath);
if (!manifest) {
  add("manifest parses", "fail", "harness.manifest.json is missing or invalid JSON.");
} else {
  const requiredCommands = ["ralph", "mine", "scout", "ingest", "voice", "bot", "verify"];
  const requiredEnv = [
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_CHAT_ID",
    "APIFY_TOKEN",
    "X_HANDLE",
    "X_BEARER_TOKEN",
    "X_CONSUMER_KEY",
    "X_CONSUMER_SECRET",
    "X_ACCESS_TOKEN",
    "X_ACCESS_TOKEN_SECRET",
    "DISCORD_USER_TOKEN",
    "DISCORD_CHANNELS",
    "OPENAI_API_KEY",
    "CODEX_MODEL",
    "PRODUCT_SPEC_PATH",
    "PRODUCT_NAME",
    "OPERATOR_NAME",
    "TARGET_AUDIENCE",
    "CONTEXT_NAME",
    "PRODUCT_FIT_RUBRIC",
    "DRY_RUN",
    "KILL_SWITCH",
    "DAILY_POST_CAP",
    "GRACE_PERIOD_SECONDS"
  ];
  const requiredInputs = [
    "../templates/product.template.md",
    "../product.md",
    "../campaigns/**",
    ".env",
    "cache/x/{date}.json",
    "cache/discord/{channel}/{date}.json",
    "voice/profile.md",
    "External tracker"
  ];
  const requiredOutputs = [
    "cache/pending-drafts.json",
    "cache/stop-flags.json",
    "cache/post-counter.json",
    "../product.md#6",
    "test-results/.last-run.json",
    "Telegram approval inbox",
    "X post"
  ];
  const requiredStateFiles = [
    ".env",
    "../product.md",
    "../campaigns/",
    "../drafts/",
    "cache/",
    "voice/",
    "voice/profile.md",
    "voice/corpus.jsonl",
    "log/",
    "test-results/.last-run.json"
  ];
  const commandNamesList = manifest.commands.map((c) => c.name);
  const envNamesList = manifest.env.map((e) => e.name);
  const inputPaths = new Set(manifest.inputs.map((i) => i.path));
  const outputPaths = new Set(manifest.outputs.map((o) => o.path));
  const statePaths = new Set(manifest.stateFiles.map((s) => s.path));
  const gateNamesList = manifest.safetyGates.map((g) => g.name);
  const commandNames = new Set(commandNamesList);
  const envNames = new Set(envNamesList);
  const gateNames = new Set(gateNamesList);
  const requiredByCommands = new Set(manifest.commands.flatMap((c) => c.safetyRequired ?? []));
  const manifestMisses = [
    ...missingFrom(requiredCommands, commandNames).map((c) => `missing command: ${c}`),
    ...requiredCommands.filter((c) => !manifest.commands.find((cmd) => cmd.name === c)?.command).map((c) => `command ${c} missing command string`),
    ...missingFrom(requiredEnv, envNames).map((e) => `missing env: ${e}`),
    ...missingFrom(requiredInputs, inputPaths).map((p) => `missing input: ${p}`),
    ...missingFrom(requiredOutputs, outputPaths).map((p) => `missing output: ${p}`),
    ...missingFrom(requiredStateFiles, statePaths).map((p) => `missing state file: ${p}`),
    ...missingFrom([...requiredByCommands], gateNames).map((g) => `safetyRequired has no gate: ${g}`),
    ...gateNamesList.filter((g) => !requiredByCommands.has(g)).map((g) => `safety gate is not required by any command: ${g}`),
    ...duplicates(commandNamesList).map((c) => `duplicate command: ${c}`),
    ...duplicates(envNamesList).map((e) => `duplicate env: ${e}`),
    ...duplicates(gateNamesList).map((g) => `duplicate safety gate: ${g}`)
  ];
  if (manifest.commands.length !== requiredCommands.length) manifestMisses.push(`expected ${requiredCommands.length} commands, found ${manifest.commands.length}`);
  if (manifest.env.length !== requiredEnv.length) manifestMisses.push(`expected ${requiredEnv.length} env vars, found ${manifest.env.length}`);
  add(
    "manifest contract",
    manifestMisses.length === 0 ? "pass" : "fail",
    `Manifest declares ${manifest.commands.length} commands, ${manifest.env.length} env vars, ${manifest.inputs.length} inputs, ${manifest.outputs.length} outputs, ${manifest.stateFiles.length} state files, and ${manifest.safetyGates.length} safety gates.`,
    manifestMisses
  );

  const exampleKeys = envKeys(resolve(harnessRoot, ".env.example"));
  const envPath = resolve(harnessRoot, ".env");
  const actualKeys = envKeys(envPath);
  const missingExampleKeys = manifest.env.map((e) => e.name).filter((key) => !exampleKeys.has(key));
  const safetyKeys = ["DRY_RUN", "KILL_SWITCH", "DAILY_POST_CAP", "GRACE_PERIOD_SECONDS"];
  const missingSafetyKeys = safetyKeys.filter((key) => existsSync(envPath) && !actualKeys.has(key));
  const dryRunKeys = ["TELEGRAM_BOT_TOKEN", "TELEGRAM_CHAT_ID"];
  const missingDryRunKeys = dryRunKeys.filter((key) => existsSync(envPath) && !actualKeys.has(key));
  add(
    ".env shape",
    missingExampleKeys.length === 0 && missingSafetyKeys.length === 0 ? (missingDryRunKeys.length === 0 ? "pass" : "warn") : "fail",
    existsSync(envPath)
      ? `.env exists with ${actualKeys.size} keys; verifier checked key names only and printed no values.`
      : ".env is absent; verifier checked .env.example only.",
    [
      ...missingExampleKeys.map((key) => `.env.example missing ${key}`),
      ...missingSafetyKeys.map((key) => `.env missing safety key ${key}`),
      ...missingDryRunKeys.map((key) => `.env missing dry-run Telegram key ${key}`)
    ]
  );
}

try {
  const spec = readSpec(resolve(projectRoot, "templates/product.template.md"));
  const sectionNumbers = [...spec.sections.keys()].sort((a, b) => a - b);
  const expectedSections = new Map<number, string>([
    [1, "Goal"],
    [2, "Done"],
    [3, "Observe"],
    [4, "Think"],
    [5, "Plan"],
    [6, "Execute"],
    [7, "Verify"],
    [8, "Reflect-if-passed"]
  ]);
  const expectedNumbers = [...expectedSections.keys()];
  const missingSections = expectedNumbers.filter((n) => !spec.sections.has(n));
  const unexpectedSections = sectionNumbers.filter((n) => !expectedSections.has(n));
  const outOfOrder = sectionNumbers.join(",") !== expectedNumbers.join(",");
  const titleMisses = expectedNumbers.flatMap((n) => {
    const section = spec.sections.get(n);
    const expected = expectedSections.get(n);
    return section && expected && section.title === expected ? [] : [`section ${n} title should be "${expected}"`];
  });
  const crit = criteria(spec);
  const needs = unfulfilledHumanInputs(spec);
  const tasks = pendingTasks(spec);
  const specMisses = [
    ...missingSections.map((n) => `missing section ${n}`),
    ...unexpectedSections.map((n) => `unexpected section ${n}`),
    ...(outOfOrder ? [`section order is ${sectionNumbers.join(" -> ")}`] : []),
    ...titleMisses,
    ...(crit.length > 0 ? [] : ["section 2 has no checkbox criteria"])
  ];
  add(
    "spec parses",
    specMisses.length === 0 ? "pass" : "fail",
    `Found ordered loop ${expectedNumbers.map((n) => expectedSections.get(n)).join(" -> ")}; ${crit.length} criteria, ${needs.length} open human inputs, ${tasks.length} pending AI tasks.`,
    specMisses
  );
} catch (error) {
  add("spec parses", "fail", `Could not parse templates/product.template.md: ${(error as Error).message}`);
}

const docsToCheck = [
  { path: resolve(harnessRoot, "README.md"), needles: ["DRY_RUN=1", "KILL_SWITCH=1", "GRACE_PERIOD_SECONDS"] },
  { path: resolve(harnessRoot, "docs/architecture.md"), needles: ["product-agnostic", "Telegram", "DRY_RUN=1"] },
  { path: resolve(harnessRoot, "docs/events.md"), needles: ["draft.approved", "post.dry_run", "KILL_SWITCH=1"] },
  { path: resolve(harnessRoot, "docs/readiness-gate.md"), needles: ["Tracker columns ready", "Required product links confirmed", "Daily send cap defined"] },
  { path: resolve(harnessRoot, "docs/operator-dry-run-demo.md"), needles: ["bun run demo:safety", "bun run demo:send", "bun run demo:proof", "demo/demo-input.json", "DRY_RUN=1"] },
  { path: resolve(harnessRoot, "docs/demo.env.example"), needles: ["TELEGRAM_BOT_TOKEN", "TELEGRAM_CHAT_ID", "PRODUCT_NAME", "DRY_RUN=1", "KILL_SWITCH=0"] }
];
const docMisses: string[] = [];
for (const doc of docsToCheck) {
  const text = existsSync(doc.path) ? readFileSync(doc.path, "utf8") : "";
  for (const needle of doc.needles) {
    if (!text.includes(needle)) docMisses.push(`${rel(doc.path)} missing "${needle}"`);
  }
}
add(
  "safety docs",
  docMisses.length === 0 ? "pass" : "fail",
  "Docs cover dry-run, kill switch, events, and readiness gate.",
  docMisses
);

const tsFiles = allFiles(harnessRoot).filter((file) => file.endsWith(".ts"));
const publishCallLocations: string[] = [];
for (const file of tsFiles) {
  const text = readFileSync(file, "utf8");
  if (text.includes("publishX(")) publishCallLocations.push(rel(file));
}
const allowedPublishLocations = new Set(["publish/x-post.ts", "telegram/bot.ts"]);
const disallowedPublishLocations = publishCallLocations.filter((file) => !allowedPublishLocations.has(file));
const botText = readFileSync(resolve(harnessRoot, "telegram/bot.ts"), "utf8");
const publishText = readFileSync(resolve(harnessRoot, "publish/x-post.ts"), "utf8");
const approvalOrder = [
  { name: "approve callback", needle: 'action === "approve"' },
  { name: "Scout manual-only block", needle: 'draft.lane === "scout-lead"' },
  { name: "content filter", needle: "contentFilter(draft.body)" },
  { name: "pre-publish guard", needle: "checkPrePublish()" },
  { name: "grace timer", needle: "setTimeout" },
  { name: "dry-run branch", needle: 'if (process.env.DRY_RUN === "1")' },
  { name: "live publish", needle: "publishX(draft.body)" },
  { name: "post counter", needle: "recordPublish()" }
];
const approvalPositions = approvalOrder.map((item) => ({ ...item, index: botText.indexOf(item.needle) }));
const missingApprovalNeedles = approvalPositions.filter((item) => item.index < 0).map((item) => item.name);
const approvalOrderingFailures = approvalPositions
  .slice(1)
  .filter((item, i) => approvalPositions[i]!.index >= 0 && item.index >= 0 && item.index < approvalPositions[i]!.index)
  .map((item) => `${item.name} appears before ${approvalPositions[approvalPositions.indexOf(item) - 1]?.name ?? "previous gate"}`);
const stopNeedles = ['action === "stop"', "loadStops()", "stops[id]", "saveStops(stops)"];
const missingStopNeedles = stopNeedles.filter((needle) => !botText.includes(needle));
const dryRunPublishGuard = publishText.includes('process.env.DRY_RUN === "1"') && publishText.includes("DRY_RUN=1 blocks live X publish");
add(
  "publish requires Telegram approval path",
  disallowedPublishLocations.length === 0 && missingApprovalNeedles.length === 0 && approvalOrderingFailures.length === 0 && missingStopNeedles.length === 0 && dryRunPublishGuard ? "pass" : "fail",
  `publishX references found in: ${publishCallLocations.join(", ")}.`,
  [
    ...disallowedPublishLocations.map((file) => `unexpected publishX reference in ${file}`),
    ...missingApprovalNeedles.map((gate) => `telegram/bot.ts missing ${gate}`),
    ...approvalOrderingFailures,
    ...missingStopNeedles.map((needle) => `STOP grace path missing ${needle}`),
    ...(dryRunPublishGuard ? [] : ["publish/x-post.ts missing DRY_RUN=1 live-publish guard"])
  ]
);

const sendText = readFileSync(resolve(harnessRoot, "telegram/send.ts"), "utf8");
const dmComposeText = readFileSync(resolve(harnessRoot, "scout/dm-compose.ts"), "utf8");
const scoutMisses = [
  ...(botText.includes('draft.lane === "scout-lead"') && botText.includes("Scout DMs are manual-only.") ? [] : ["telegram/bot.ts does not block approve callbacks for scout-lead drafts"]),
  ...(sendText.includes('draft.lane === "scout-lead"') && sendText.includes("manual DM only") ? [] : ["telegram/send.ts does not render Scout drafts as manual-only"]),
  ...(dmComposeText.includes("registerDraft(draft)") && dmComposeText.includes("await sendDraft(draft)") ? [] : ["scout/dm-compose.ts does not queue Scout drafts through Telegram"]),
  ...(dmComposeText.includes("publishX") || dmComposeText.includes("TwitterApi") ? ["scout/dm-compose.ts contains a live X send/publish dependency"] : [])
];
add(
  "scout DMs manual-only",
  scoutMisses.length === 0 ? "pass" : "fail",
  "Scout drafts route to Telegram and approve callbacks are blocked from live publish.",
  scoutMisses
);

const ignoredPaths = [
  ".env",
  "AGENTS.md",
  "CLAUDE.md",
  "_TEMPLATE.md",
  "product.md",
  "products/private-product.md",
  "campaigns/private-campaign/spec.md",
  "drafts/private-draft.md",
  "private/notes.md",
  "example-referral.md",
  "example-referral/private.md",
  "harness/.env",
  "harness/cache/runtime-state.json",
  "harness/demo/demo-input.json",
  "harness/test-results/telegram-approval-evidence.json",
  "harness/voice/profile.md",
  "harness/voice/corpus.jsonl",
  "harness/voice/generated-anchor.md",
  "harness/log/runtime.log",
  "harness/miner/output/.state",
  "harness/scout/output/.state",
  "harness/test-results/.last-run.json"
];
const ignoreFailures: string[] = [];
for (const path of ignoredPaths) {
  const ignored = gitCheckIgnored(path);
  if (ignored !== true) ignoreFailures.push(ignored === null ? `${path}: no git repo` : `${path}: not ignored`);
}
add(
  "private and runtime state ignored",
  ignoreFailures.length === 0 ? "pass" : "fail",
  `${ignoredPaths.length} private/runtime paths checked with git check-ignore.`,
  ignoreFailures
);

const packageJson = readJson<{ scripts?: Record<string, string> }>(resolve(harnessRoot, "package.json"));
const packageMisses = [
  ...(packageJson?.scripts?.verify === "bun scripts/verify-harness" ? [] : ["package script verify should be bun scripts/verify-harness"]),
  ...(packageJson?.scripts?.["demo:bootstrap"] === "bun scripts/demo-bootstrap" ? [] : ["package script demo:bootstrap should be bun scripts/demo-bootstrap"]),
  ...(packageJson?.scripts?.["demo:safety"] === "bun scripts/demo-local-safety" ? [] : ["package script demo:safety should be bun scripts/demo-local-safety"]),
  ...(packageJson?.scripts?.["demo:ready"] === "bun scripts/demo-readiness" ? [] : ["package script demo:ready should be bun scripts/demo-readiness"]),
  ...(packageJson?.scripts?.["demo:send"] === "bun scripts/demo-send-drafts" ? [] : ["package script demo:send should be bun scripts/demo-send-drafts"]),
  ...(packageJson?.scripts?.["demo:proof"] === "bun scripts/demo-approval-proof" ? [] : ["package script demo:proof should be bun scripts/demo-approval-proof"]),
  ...(packageJson?.scripts?.["demo:run"] === "bun scripts/demo-run" ? [] : ["package script demo:run should be bun scripts/demo-run"]),
  ...(packageJson?.scripts?.["demo:operator"] === "bun scripts/demo-operator" ? [] : ["package script demo:operator should be bun scripts/demo-operator"]),
  ...(packageJson?.scripts?.["demo:status"] === "bun scripts/demo-status" ? [] : ["package script demo:status should be bun scripts/demo-status"])
];
add(
  "verify command",
  packageMisses.length === 0 ? "pass" : "fail",
  packageJson?.scripts?.verify ? "package scripts expose verify and operator demo checks." : "package scripts are missing.",
  packageMisses
);

const status: Status = checks.some((check) => check.status === "fail")
  ? "fail"
  : checks.some((check) => check.status === "warn")
    ? "warn"
    : "pass";

const result = {
  status,
  checkedAt: new Date().toISOString(),
  harnessRoot,
  projectRoot,
  checks,
  safetyEvidence: {
    noSecretsPrinted: true,
    externalApisCalled: false,
    livePublishAttempted: false,
    campaignScaleStarted: false
  }
};

mkdirSync(dirname(resultPath), { recursive: true });
writeFileSync(resultPath, `${JSON.stringify(result, null, 2)}\n`);

for (const check of checks) {
  const symbol = check.status === "pass" ? "PASS" : check.status === "warn" ? "WARN" : "FAIL";
  console.log(`${symbol} ${check.name}: ${check.evidence}`);
  if (check.details?.length) {
    for (const detail of check.details) console.log(`  - ${detail}`);
  }
}
console.log(`\nresult: ${status}`);
console.log(`wrote: ${rel(resultPath)}`);

if (status === "fail") process.exit(1);
